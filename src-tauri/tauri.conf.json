{
  "productName": "Alacrity",
  "version": "0.1.0",
  "identifier": "com.alacrity.app",
  "build": {
    "beforeDevCommand": "bun run --cwd client dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run --cwd client build",
    "frontendDist": "../client/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Alacrity",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* https://tauri.localhost; img-src 'self' http://localhost:* data: blob:; media-src 'self' http://localhost:*; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "app", "dmg", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/alacrity-server"],
    "resources": {
      "../data/pokemon.db": "data/pokemon.db",
      "../scripts/lua": "scripts/lua",
      "../scripts/shiny_hunter_core": "scripts/shiny_hunter_core",
      "../scripts/shiny_hunter_wild": "scripts/shiny_hunter_wild",
      "../scripts/shiny_hunter_egg": "scripts/shiny_hunter_egg",
      "../server/src/data": "server/src/data",
      "resources/bin/bsdtar-linux-x64": "bin/bsdtar-linux-x64",
      "resources/data/libarchive-LICENSE.txt": "data/libarchive-LICENSE.txt"
    }
  }
}
