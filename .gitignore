# ─── Dependencies ────────────────────────────────
node_modules/
.superpowers/
.worktrees/
.claude/
.playwright-mcp/

# ─── Internal planning docs (kept local) ─────────
docs/superpowers/

# ─── User data (never commit) ────────────────────
# ROMs are copyrighted — users provide their own
roms/
# Save files contain personal game data
saves/
# Hunt instance data is per-user runtime state
hunts/
# Auto-installed emulators live here (per-checkout, per-OS)
emulators/
# Local SQLite database is a build artifact
/data/
server/data/
server/pokemon.db

# ─── Third-party tools (not our code) ────────────
# Emulators, BIOS files, native binaries — users download separately
tools/*
# RTC relay is our Go code — track source, ignore compiled binary
!tools/rtc-relay/
tools/rtc-relay/rtc-relay
# mGBA streaming bridge is our C code — track source, ignore compiled binaries and any libmgba copied alongside for rpath
!tools/mgba-stream/
tools/mgba-stream/mgba-stream
tools/mgba-stream/mgba-stream-debug
tools/mgba-stream/libmgba.so*
tools/mgba-stream/libmgba*.dylib

# ─── Build artifacts ─────────────────────────────
src-tauri/target/
src-tauri/gen/
client/dist/
client/node_modules/.vite/
server/src/scripts/.cache/

# ─── Compiled sidecar (huge, built by CI) ────────
src-tauri/binaries/alacrity-server-*-*
!src-tauri/binaries/alacrity-server-dev-wrapper
# bun build --compile intermediate files (stray .bun-build artifacts)
.*.bun-build

# ─── Compiled C hunt binaries + bundled libmgba (built on each platform) ───
scripts/shiny_hunter_core
scripts/shiny_hunter_wild
scripts/shiny_hunter_egg
scripts/libmgba.so*
scripts/libmgba*.dylib
scripts/mgba*.dll

# ─── Secrets / local config ──────────────────────
.env
.env.local
config.json

# ─── OS cruft ────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~

# Local debug captures and bundled-resource copies
src-tauri/canvas-test.png
src-tauri/stream-*.png
src-tauri/data/
tools/rtc-relay/rtc-relay.exe
.sprite-cache/
.data-cache/

# Local script backups + stray sqlite scratch files
.backups/
server/src/db.sqlite3

# Sprites are bundled at build time via `bun run fetch-sprites` (see scripts/fetch-sprites.ts).
# They land in client/dist/ (a Tauri resource) so the shipped app stays offline-capable.
client/public/sprites/
